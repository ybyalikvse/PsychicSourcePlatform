# ===========================================
# SERVER ENVIRONMENT VARIABLES
# ===========================================

# Database — Supabase PostgreSQL connection string
# Use the POOLER URL (port 6543) for Vercel serverless, direct URL (port 5432) for local dev
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Server
PORT=5000
NODE_ENV=development

# ===========================================
# AWS S3 — Video & image uploads
# ===========================================
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_PUBLIC=true

# ===========================================
# AI — OpenRouter (single key for Claude, GPT-4o, etc.)
# Get from https://openrouter.ai/keys
# ===========================================
OPENROUTER_API_KEY=

# ===========================================
# Firebase — Server-side admin + Client-side auth
# ===========================================
# Client-side (prefix with VITE_ so Vite exposes them to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ===========================================
# Google OAuth — Search Console & Analytics integrations
# ===========================================
GOOGLE_SEARCH_CONSOLE_CLIENT_ID=
GOOGLE_SEARCH_CONSOLE_CLIENT_SECRET=
GOOGLE_ANALYTICS_CLIENT_ID=
GOOGLE_ANALYTICS_CLIENT_SECRET=

# ===========================================
# Firecrawl — Web scraping for content optimization
# ===========================================
FIRECRAWL_API_KEY=

# ===========================================
# Google Analytics — Client-side tracking
# ===========================================
VITE_GA_MEASUREMENT_ID=

# ===========================================
# Cron Jobs — Secret for authenticating GitHub Actions → Vercel cron endpoints
# ===========================================
CRON_SECRET=

# ===========================================
# GitHub Actions Secrets (set in GitHub repo settings, NOT in .env)
# ===========================================
# VERCEL_APP_URL=https://your-app.vercel.app
# CRON_SECRET=(same value as above)
