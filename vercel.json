{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "server/**,shared/**",
      "maxDuration": 60
    },
    "api/cron/*.ts": {
      "includeFiles": "server/**,shared/**",
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/cron/horoscopes", "destination": "/api/cron/horoscopes.ts" },
    { "source": "/api/cron/video-cleanup", "destination": "/api/cron/video-cleanup.ts" },
    { "source": "/api/(.*)", "destination": "/api/index.ts" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
