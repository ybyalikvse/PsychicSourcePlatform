{
  "buildCommand": "npm run build:vercel",
  "outputDirectory": "dist/public",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/cron/horoscopes.js": {
      "maxDuration": 300
    },
    "api/cron/video-cleanup.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/cron/horoscopes", "destination": "/api/cron/horoscopes.js" },
    { "source": "/api/cron/video-cleanup", "destination": "/api/cron/video-cleanup.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
